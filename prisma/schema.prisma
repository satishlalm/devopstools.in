// PostgreSQL schema for DevOpsTools.in
// Powers newsletter, tool analytics, blog CMS and (future) saved snippets.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  confirmed Boolean  @default(false)
}

model ToolUsage {
  id        String   @id @default(cuid())
  toolSlug  String
  day       DateTime @db.Date
  count     Int      @default(0)

  @@unique([toolSlug, day])
  @@index([toolSlug])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String
  category    String
  contentMd   String    @db.Text
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ToolRequest {
  id        String   @id @default(cuid())
  name      String
  details   String   @db.Text
  email     String?
  status    String   @default("open") // open | building | shipped | declined
  createdAt DateTime @default(now())
}

// For Auth.js (when accounts/saved-snippets ship)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  snippets  Snippet[]
}

model Snippet {
  id        String   @id @default(cuid())
  userId    String
  toolSlug  String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
